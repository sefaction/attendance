# Container name shown in Unraid
CONTAINER_NAME=attendance-tracker

# Host port exposed by Unraid (open http://<unraid-ip>:HOST_PORT)
HOST_PORT=8080

# Persist app data on Unraid array/cache
# Example path: /mnt/user/appdata/attendance-tracker
APPDATA_PATH=/mnt/user/appdata/attendance-tracker

# SQLite path inside the container
ATTENDANCE_DB=/data/attendance.db
